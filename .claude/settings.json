{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/preferences/inject-preferences.sh"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/packs/load-active-prose.mjs"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/skills/mount-skills.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/checks/pretooluse-guard.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/checks/stop-hook.mjs"
          }
        ]
      }
    ]
  }
}
